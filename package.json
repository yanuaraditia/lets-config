{
  "name": "runtime-config-monorepo",
  "private": true,
  "version": "0.1.1",
  "description": "Framework-agnostic runtime config — inspired by Nuxt 3/4 useRuntimeConfig",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --filter='*' run build",
    "dev": "bun --filter='*' run dev",
    "clean": "bun --filter='*' run clean",
    "pub": "bun run build && bun --filter='*' publish",
    "pub:dry": "bun run build && bun --filter='*' publish --dry-run",
    "release": "changelogen --release --bump",
    "release-minor": "changelogen --release --minor",
    "release-patch": "changelogen --release --patch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "changelogen": "^0.6.2",
    "typescript": "^6.0.3"
  }
}
