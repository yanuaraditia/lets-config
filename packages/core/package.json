{
  "name": "lets-config",
  "version": "0.1.0",
  "description": "Framework-agnostic runtime config core — types, defineRuntimeConfig, env overrides",
  "keywords": ["runtime-config", "vite", "nuxt", "useRuntimeConfig"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  }
}
