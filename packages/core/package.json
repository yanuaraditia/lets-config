{
  "name": "lets-config",
  "version": "0.1.0",
  "description": "Framework-agnostic runtime config core — types, defineRuntimeConfig, env overrides",
  "keywords": ["runtime-config", "vite", "nuxt", "useRuntimeConfig"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "rimraf": "^5.0.5",
    "tsdown": "latest",
    "typescript": "^5.4.5"
  }
}
