{
  "name": "@lets-config/react",
  "version": "0.1.0",
  "description": "React bindings for @runtime-config — useRuntimeConfig hook, provider, SSR utilities",
  "keywords": ["runtime-config", "react", "vite", "useRuntimeConfig", "react-router"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "lets-config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "react": "^18.3.1",
    "rimraf": "^5.0.5",
    "tsdown": "latest",
    "typescript": "^5.4.5"
  }
}
