{
  "name": "@lets-config/vite",
  "version": "0.1.0",
  "description": "Vite plugin for @runtime-config — HTML injection, virtual modules, HMR, type generation",
  "keywords": [
    "vite-plugin",
    "runtime-config",
    "vite",
    "useRuntimeConfig"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vite": "^8.0.9"
  },
  "optionalDependencies": {
    "jiti": "^2.6.1"
  },
  "dependencies": {
    "lets-config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
