{
  "name": "@yanuaraditia/config",
  "version": "0.1.6",
  "description": "Runtime config for Vite + React — defineRuntimeConfig, Vite plugin, env overrides",
  "homepage": "https://github.com/yanuaraditia/config#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanuaraditia/config.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/yanuaraditia/config/issues"
  },
  "keywords": [
    "vite-plugin",
    "runtime-config",
    "vite",
    "useRuntimeConfig"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "peerDependencies": {
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@yanuaraditia/config-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
