{
  "name": "@lets-config/vite",
  "version": "0.1.0",
  "description": "Vite plugin for @runtime-config — HTML injection, virtual modules, HMR, type generation",
  "keywords": ["vite-plugin", "runtime-config", "vite", "useRuntimeConfig"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "virtual.d.ts"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "optionalDependencies": {
    "jiti": "^2.0.0"
  },
  "dependencies": {
    "lets-config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "jiti": "^2.0.0",
    "rimraf": "^5.0.5",
    "tsdown": "latest",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
